# MailMind — .gitignore
# Keep secrets, build artifacts, and local state out of version control.

# --- OAuth tokens (contains private access + refresh tokens) ---
token.json

# --- Environment variables (contains API keys) ---
.env

# --- Python ---
__pycache__/
__pycache__
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
*.egg-info/
dist/
build/

# --- Database (local SQLite file) ---
*.db
*.sqlite

# --- Node / Tailwind build ---
node_modules/

# --- IDE ---
.vscode/
.idea/
*.DS_Store

# --- ML Training data (large CSV files, download separately) ---
train/train.csv
train/test.csv

# --- Trained models (generated by train/train_classifier.py) ---
backend/pipeline/models/
